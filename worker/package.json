{
  "name": "bibliotheca-parva",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "NODE_OPTIONS='--import tsx' cucumber-js",
    "test:all": "vitest run && npm run test:acceptance",
    "types": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply bibliotheca-parva --local",
    "import": "python3 scripts/import_dump.py ../db-backup.sql.bz2 seed.sql",
    "seed:local": "wrangler d1 execute bibliotheca-parva --local --file=./seed.sql",
    "bootstrap:local": "npm run migrate:local && npm run import && npm run seed:local",
    "reset:local": "rm -rf .wrangler/state/v3/d1 && npm run bootstrap:local"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@cucumber/cucumber": "^12.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  }
}
