{
	"name": "bibliotheca-parva",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"deploy": "npm run build && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"knip": "knip",
		"migrate:local": "wrangler d1 migrations apply bibliotheca-parva --local",
		"import": "python3 scripts/import_dump.py db-backup.sql.bz2 seed.sql",
		"seed:local": "wrangler d1 execute bibliotheca-parva --local --file=./seed.sql",
		"bootstrap:local": "npm run migrate:local && npm run import && npm run seed:local",
		"reset:local": "rm -rf .wrangler/state/v3/d1 && npm run bootstrap:local",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"test:mutation": "svelte-kit sync && stryker run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^26.0.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"knip": "^6.22.0",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.8",
		"wrangler": "^4.105.0"
	},
	"dependencies": {
		"jose": "^6.2.3"
	}
}
