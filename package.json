{
	"name": "bibliotheca-parva",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"deploy": "npm run build && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"migrate:local": "wrangler d1 migrations apply bibliotheca-parva --local",
		"import": "python3 scripts/import_dump.py db-backup.sql.bz2 seed.sql",
		"seed:local": "wrangler d1 execute bibliotheca-parva --local --file=./seed.sql",
		"bootstrap:local": "npm run migrate:local && npm run import && npm run seed:local",
		"reset:local": "rm -rf .wrangler/state/v3/d1 && npm run bootstrap:local",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"test:mutation": "svelte-kit sync && stryker run"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^26.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.97.0"
	}
}
